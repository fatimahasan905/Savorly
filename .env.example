# ─── SAVORLY ENVIRONMENT VARIABLES ───────────────────────────────────────────
# Copy this file, rename it to .env.local, and fill in your values.
# NEVER commit .env.local to git. It is already in .gitignore.

# ── ANTHROPIC (AI features) ───────────────────────────────────────────────────
# Get this from: https://console.anthropic.com → API Keys → Create Key
# Used for: recipe generation, recipe URL parsing
# Cost: ~$0.003 per recipe generation (very cheap)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── SUPABASE (database + auth) ────────────────────────────────────────────────
# Get both values from: https://supabase.com → your project → Settings → API
# VITE_ prefix makes them available in the frontend (these are safe to expose)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─────────────────────────────────────────────────────────────────────────────
# NOTE: ANTHROPIC_API_KEY does NOT have the VITE_ prefix on purpose.
# This means it is only available in Vercel's server functions (api/ folder)
# and is NEVER sent to the user's browser. This is what keeps your key safe.
# ─────────────────────────────────────────────────────────────────────────────
